# Supabase Project Settings > Connect > Supavisor Session pooler.
DATABASE_URL="postgres://prisma.[PROJECT-REF]:[PRISMA-PASSWORD]@[DB-REGION].pooler.supabase.com:5432/postgres?sslmode=require"
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
EMAIL_SERVER=""
EMAIL_FROM="noreply@example.com"
ADMIN_EMAIL="admin@example.com"

# Supabase Storage private bucket for identity verification proof files.
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="verification-proofs"
